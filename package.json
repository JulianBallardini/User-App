{
  "name": "5-users-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.{js,ts,html}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{js,ts,html}\" --fix --max-warnings=0",
    "lint:tests": "eslint \"src/**/*.{test,spec}.{js,ts}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,ts,html,css,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,html,css,scss,json,md}\"",
    "validate": "npm run lint && npm run format:check && npm run test:run"
  },
  "type": "module",
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@ng-bootstrap/ng-bootstrap": "^19.0.1",
    "@ngrx/effects": "^20.1.0",
    "@ngrx/store": "^20.1.0",
    "@ngrx/store-devtools": "^20.1.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.6",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.17",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.13",
    "@angular/cli": "^20.3.13",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/localize": "^20.3.0",
    "@eslint/js": "^9.39.2",
    "@html-eslint/eslint-plugin": "^0.52.1",
    "@html-eslint/parser": "^0.52.0",
    "@testing-library/angular": "^18.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-angular": "^5.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^27.4.0",
    "karma-coverage": "~2.2.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
